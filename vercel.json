{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
"headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/event-reminders", "schedule": "0 * * * *" },
    { "path": "/api/cron/no-rsvp-nudge", "schedule": "15 * * * *" },
    { "path": "/api/cron/feedback-prompts", "schedule": "30 * * * *" },
    { "path": "/api/cron/reputation-recompute", "schedule": "0 4 * * *" },
    { "path": "/api/cron/patch-digest", "schedule": "0 15 * * 1" }
  ]
}
